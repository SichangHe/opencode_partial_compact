{
  "name": "opencode-partial-compact",
  "version": "0.1.0",
  "type": "module",
  "description": "Agent-driven partial context compaction plugin for Opencode.",
  "main": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./server": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./tui": {
      "import": "./dist/tui.js",
      "types": "./dist/tui.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.15.0",
    "@opencode-ai/sdk": ">=1.15.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.15.10",
    "@opencode-ai/sdk": "1.15.10",
    "@types/bun": "latest",
    "@types/node": "^22.19.19",
    "typescript": "^6.0.3"
  }
}
