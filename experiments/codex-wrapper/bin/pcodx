#!/usr/bin/env bash
set -euo pipefail

self=$(readlink -f "${BASH_SOURCE[0]}")
root=$(cd -- "$(dirname -- "$(dirname -- "$self")")" && pwd)

pcodx_state_root() {
  printf '%s/pcodx\n' "${XDG_STATE_HOME:-$HOME/.local/state}"
}

pcodx_cwd_prefix() {
  local label hash
  label=$(basename -- "$PWD" | sed 's/[^A-Za-z0-9_.-]/-/g')
  [[ -n "$label" ]] || label=cwd
  hash=$(printf '%s' "$PWD" | sha256sum | cut -c1-12)
  printf '%s-%s\n' "$label" "$hash"
}

pcodx_new_run_dir() {
  printf '%s/runs/%s/%s-%s-%s\n' "$(pcodx_state_root)" "$(date -u +%F)" "$(pcodx_cwd_prefix)" "$(date -u +%Y%m%dT%H%M%S)" "$$"
}

for arg in "$@"; do
  [[ "$arg" == "--" ]] && break
  if [[ "$arg" == "--help" || "$arg" == "-h" || "$arg" == "help" ]]; then
    exec bun run "$root/src/frontend-cli.ts" --help
  fi
done

if [[ "${1:-}" == "sidecar" || "${1:-}" == "debug-sidecar" || "${1:-}" == "server" ]]; then
  shift
  export PCODX_MODE=1
  export PCODX_POC_ROOT="${PCODX_POC_ROOT:-$root}"
  export PCODX_RUN_DIR="${PCODX_RUN_DIR:-$(pcodx_new_run_dir)}"
  export PCODX_LEDGER_PATH="${PCODX_LEDGER_PATH:-$PCODX_RUN_DIR/pcodx-ledger.json}"
  export PCODX_SESSION_ID="${PCODX_SESSION_ID:-pcodx-sidecar}"
  mkdir -p "$PCODX_RUN_DIR"

  trim() {
    local value="$1"
    value="${value#"${value%%[![:space:]]*}"}"
    value="${value%"${value##*[![:space:]]}"}"
    printf '%s\n' "$value"
  }

  config_key() {
    trim "${1%%=*}"
  }

  config_allowed() {
    local spec="$1"
    [[ "$spec" == *=* && "$spec" != *$'\n'* && "$spec" != *$'\r'* ]] || return 1
    [[ "$(config_key "$spec")" == "model_reasoning_effort" ]] || return 1
    case "$(trim "${spec#*=}")" in
      low|medium|high|xhigh|'"low"'|'"medium"'|'"high"'|'"xhigh"'|"'low'"|"'medium'"|"'high'"|"'xhigh'") return 0 ;;
      *) return 1 ;;
    esac
  }

  reject_config() {
    echo "pcodx owns Codex config injection; pass task instructions as prompt text instead" >&2
    exit 2
  }

  prev_arg_was_config=0
  forward_args=()
  pcodx_allowed_configs=()
  for arg in "$@"; do
    if [[ "$prev_arg_was_config" == 1 ]]; then
      config_allowed "$arg" || reject_config
      pcodx_allowed_configs+=(--config "$arg")
      prev_arg_was_config=0
      continue
    fi
    case "$arg" in
      -c|--config)
        prev_arg_was_config=1
        ;;
      --config=*)
        config_value="${arg#--config=}"
        config_allowed "$config_value" || reject_config
        pcodx_allowed_configs+=(--config "$config_value")
        ;;
      -c*)
        config_value="${arg#-c}"
        config_allowed "$config_value" || reject_config
        pcodx_allowed_configs+=(--config "$config_value")
        ;;
      *)
        forward_args+=("$arg")
        ;;
    esac
  done
  if [[ "$prev_arg_was_config" == 1 ]]; then
    reject_config
  fi

  PCODX_DEVELOPER_INSTRUCTIONS=$(bun run "$PCODX_POC_ROOT/src/pcodx-instructions.ts")
  PCODX_DEVELOPER_INSTRUCTIONS_TOML=$(PCODX_DEVELOPER_INSTRUCTIONS="$PCODX_DEVELOPER_INSTRUCTIONS" python3 -c 'import json, os; print(json.dumps(os.environ["PCODX_DEVELOPER_INSTRUCTIONS"]))')
  PCODX_LEDGER_PATH_TOML=$(PCODX_LEDGER_PATH="$PCODX_LEDGER_PATH" python3 -c 'import json, os; print(json.dumps(os.environ["PCODX_LEDGER_PATH"]))')
  PCODX_SESSION_ID_TOML=$(PCODX_SESSION_ID="$PCODX_SESSION_ID" python3 -c 'import json, os; print(json.dumps(os.environ["PCODX_SESSION_ID"]))')

  exec bunx @openai/codex \
    --dangerously-bypass-approvals-and-sandbox \
    --config "developer_instructions=$PCODX_DEVELOPER_INSTRUCTIONS_TOML" \
    --config 'mcp_servers.pcodx_partial_compact.command="bun"' \
    --config "mcp_servers.pcodx_partial_compact.args=[\"run\",\"$PCODX_POC_ROOT/src/mcp-server.ts\"]" \
    --config "mcp_servers.pcodx_partial_compact.env={PCODX_LEDGER_PATH=$PCODX_LEDGER_PATH_TOML,PCODX_SESSION_ID=$PCODX_SESSION_ID_TOML}" \
    "${pcodx_allowed_configs[@]}" \
    "${forward_args[@]}"
fi

pcodx_frontend_args=(--cwd "$PWD")
if [[ -n "${PCODX_RUN_DIR:-}" ]]; then
  pcodx_frontend_args+=(--run-dir "$PCODX_RUN_DIR")
fi
if [[ -n "${PCODX_SESSION_ID:-}" ]]; then
  pcodx_frontend_args+=(--session-id "$PCODX_SESSION_ID")
fi

exec bun run "$root/src/agent-cli.ts" frontend "${pcodx_frontend_args[@]}" -- "$@"
