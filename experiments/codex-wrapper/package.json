{
  "name": "codex-partial-compact-wrapper-poc",
  "version": "0.1.0",
  "type": "module",
  "description": "Proof-of-concept Codex app-server wrapper for message-ID partial compaction.",
  "main": "./dist/index.js",
  "bin": {
    "pcodx": "./bin/pcodx",
    "pcodx-native": "./bin/pcodx-native"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "demo": "bun run src/demo.ts",
    "agent": "bun run src/agent-cli.ts",
    "frontend": "bun run src/frontend-cli.ts",
    "controller": "bun run src/controller-cli.ts",
    "manager:agent": "bun run src/manager-agent-launch.ts",
    "mcp:server": "bun run src/mcp-server.ts",
    "smoke:live-turn": "bun run src/live-turn-smoke.ts",
    "smoke:context-shrink": "bun run src/context-shrink-smoke.ts",
    "smoke:self-compact": "bun run src/self-compact-smoke.ts",
    "smoke:controller-cli": "bun run src/controller-cli-smoke.ts",
    "smoke:frontend-proxy": "bun run src/frontend-proxy-smoke.ts",
    "smoke:mcp": "bun run src/mcp-smoke.ts",
    "smoke:pcodx-startup": "bun run src/pcodx-startup-smoke.ts",
    "verify:self-compaction": "bun run src/verify-self-compaction.ts",
    "probe:schema": "rm -rf runs/app-server-schema && codex app-server generate-ts --experimental --out runs/app-server-schema"
  },
  "devDependencies": {
    "@types/node": "^22.19.19",
    "typescript": "^6.0.3"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^4.4.3"
  }
}
